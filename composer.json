{
  "name": "vetheslav/smspby",
  "description": "SMSp.by API client for SMS and Viber messaging",
  "keywords": [
    "sms",
    "смс",
    "отправка",
    "рассылка",
    "smsp.by",
    "смс.бел",
    "api"
  ],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Slava Shahoyko",
      "email": "vistova@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "ext-json": "*",
    "psr/log": "^3.0",
    "symfony/http-client": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Vetheslav\\SmspBy\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Vetheslav\\SmspBy\\Tests\\": "tests"
    }
  }
}
